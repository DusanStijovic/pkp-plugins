msgid "plugins.generic.faqPopup.displayName"
msgstr "Brza FAQ pitanja"

msgid "plugins.generic.faqPopup.description"
msgstr "Prikazuje FAQ popup na frontend stranicama. Ukljucite plugin, izmenite FAQ stavke u locale fajlovima i po potrebi podesite questionIndexes u config.ini."

msgid "plugins.generic.faqPopup.quickQuestions"
msgstr "Brza pitanja"

msgid "plugins.generic.faqPopup.faqTitle"
msgstr "Najčešće postavljena pitanja"

msgid "plugins.generic.faqPopup.faqBody"
msgstr "Kliknite pitanje da biste videli kratak odgovor."

msgid "plugins.generic.faqPopup.defaultAnswer"
msgstr "Izaberite pitanje da biste videli odgovor ovde."

msgid "plugins.generic.faqPopup.faq.question.1"
msgstr "Koliko obično traje recenzentski postupak?"

msgid "plugins.generic.faqPopup.faq.answer.1"
msgstr "Trajanje recenzije zavisi od dostupnosti recenzenata i složenosti rada, ali se prva odluka najčešće šalje u roku od nekoliko nedelja."

msgid "plugins.generic.faqPopup.faq.question.2"
msgstr "Da li mogu da pošaljem izmenjenu verziju nakon odluke?"

msgid "plugins.generic.faqPopup.faq.answer.2"
msgstr "Da. Ako su tražene izmene, ažurirani rukopis i odgovor recenzentima šaljete kroz isti zapis predaje."

msgid "plugins.generic.faqPopup.faq.question.3"
msgstr "Koji formati fajlova su prihvaćeni za predaju?"

msgid "plugins.generic.faqPopup.faq.answer.3"
msgstr "Glavni rukopis se najčešće prihvata kao DOCX ili LaTeX PDF, a slike možete otpremiti kao zasebne fajlove visoke rezolucije."

msgid "plugins.generic.faqPopup.faq.question.4"
msgstr "Da li mi je potreban ORCID za predaju?"

msgid "plugins.generic.faqPopup.faq.answer.4"
msgstr "Neki časopisi zahtevaju ORCID za korespondentnog autora, dok ga drugi samo preporučuju. Proverite smernice za autore."

msgid "plugins.generic.faqPopup.faq.question.5"
msgstr "Da li mogu da predložim recenzente?"

msgid "plugins.generic.faqPopup.faq.answer.5"
msgstr "Mnogi časopisi to dozvoljavaju tokom predaje, ali urednik donosi konačnu odluku o izboru recenzenata."

msgid "plugins.generic.faqPopup.faq.question.6"
msgstr "Da li postoji naknada za obradu rada (APC)?"

msgid "plugins.generic.faqPopup.faq.answer.6"
msgstr "Politika APC naknada zavisi od časopisa. Pogledajte sekciju o naknadama na sajtu časopisa za aktuelne informacije i moguće oslobađanje od plaćanja."

msgid "plugins.generic.faqPopup.faq.question.7"
msgstr "Kako da pratim status svoje predaje?"

msgid "plugins.generic.faqPopup.faq.answer.7"
msgstr "Prijavite se na autorski nalog i otvorite detalje predaje, gde je prikazana trenutna urednička faza."

msgid "plugins.generic.faqPopup.faq.question.8"
msgstr "Kome da se obratim za tehničke probleme sa prijavom?"

msgid "plugins.generic.faqPopup.faq.answer.8"
msgstr "Javite se na kontakt email podrške sa sajta časopisa i pošaljite korisničko ime uz kratak opis problema."
