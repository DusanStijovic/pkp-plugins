msgid "plugins.generic.faqPopup.displayName"
msgstr "Quick Questions Popup"

msgid "plugins.generic.faqPopup.description"
msgstr "Shows an FAQ popup on frontend pages. Enable the plugin, edit locale FAQ entries, and optionally set questionIndexes in config.ini."

msgid "plugins.generic.faqPopup.quickQuestions"
msgstr "Quick Questions"

msgid "plugins.generic.faqPopup.faqTitle"
msgstr "Frequently Asked Questions"

msgid "plugins.generic.faqPopup.faqBody"
msgstr "Tap a question below to see a quick answer."

msgid "plugins.generic.faqPopup.defaultAnswer"
msgstr "Select a question to see the answer here."

msgid "plugins.generic.faqPopup.faq.question.1"
msgstr "How long does peer review usually take?"

msgid "plugins.generic.faqPopup.faq.answer.1"
msgstr "Review duration depends on reviewer availability and manuscript complexity, but most first decisions are sent within several weeks."

msgid "plugins.generic.faqPopup.faq.question.2"
msgstr "Can I submit a revised version after decision?"

msgid "plugins.generic.faqPopup.faq.answer.2"
msgstr "Yes. If revisions are requested, upload the updated manuscript and a response letter through the same submission record."

msgid "plugins.generic.faqPopup.faq.question.3"
msgstr "What file formats are accepted for submission?"

msgid "plugins.generic.faqPopup.faq.answer.3"
msgstr "The main manuscript is usually accepted in DOCX or LaTeX PDF form, and figures can be uploaded as separate high-resolution files."

msgid "plugins.generic.faqPopup.faq.question.4"
msgstr "Do I need an ORCID to submit?"

msgid "plugins.generic.faqPopup.faq.answer.4"
msgstr "Some journals require ORCID for corresponding authors, while others only recommend it. Check the journal's author requirements page."

msgid "plugins.generic.faqPopup.faq.question.5"
msgstr "Can I suggest reviewers?"

msgid "plugins.generic.faqPopup.faq.answer.5"
msgstr "Many journals allow reviewer suggestions during submission, but the editor makes the final reviewer selection."

msgid "plugins.generic.faqPopup.faq.question.6"
msgstr "Is there an article processing charge (APC)?"

msgid "plugins.generic.faqPopup.faq.answer.6"
msgstr "APC policy differs by journal. Please check the fees section on the journal website for current pricing and waiver options."

msgid "plugins.generic.faqPopup.faq.question.7"
msgstr "How do I track my submission status?"

msgid "plugins.generic.faqPopup.faq.answer.7"
msgstr "Log in to your author dashboard and open the submission details page to see the current editorial stage."

msgid "plugins.generic.faqPopup.faq.question.8"
msgstr "Who do I contact for technical login issues?"

msgid "plugins.generic.faqPopup.faq.answer.8"
msgstr "Contact the journal support email listed on the website and include your username plus a short description of the issue."
